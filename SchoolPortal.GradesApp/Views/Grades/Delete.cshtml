@model Grade

@{
    ViewData["Title"] = "Revoke Grade Record";
}

<div class="row justify-content-center mx-2 mx-md-0">
    <div class="col-lg-8">
        <div class="card-custom border-danger">
            <!-- Header warning block -->
            <div class="card-header-custom py-3 bg-danger-subtle border-danger-subtle text-danger d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-1 fw-bold"><i class="bi bi-exclamation-octagon-fill me-2"></i>Revoke Grade Record</h5>
                    <p class="text-danger opacity-75 mb-0 small">This action is irreversible and will permanently delete this database record.</p>
                </div>
                <i class="bi bi-trash3 display-6 opacity-50"></i>
            </div>

            <div class="card-body-custom p-4">
                <!-- Safety notification warning -->
                <div class="alert-custom danger mb-4">
                    <div class="alert-icon-wrapper">
                        <i class="bi bi-shield-fill-exclamation"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Are you absolutely sure?</h6>
                        <p class="mb-0 small opacity-90">Deleting this grade record will remove all academic history associated with this course instance. Please confirm the student details before proceeding.</p>
                    </div>
                </div>

                <!-- Info summary block -->
                <div class="bg-light rounded p-4 border mb-4">
                    <h6 class="fw-bold text-muted uppercase small mb-3"><i class="bi bi-info-circle me-1"></i>Record Verification</h6>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <span class="text-muted d-block small">STUDENT NAME</span>
                            <span class="fw-bold text-main fs-5">@ViewBag.StudentName</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted d-block small">COURSE TITLE</span>
                            <span class="fw-bold text-main fs-5">@Model.CourseName</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted d-block small">SCORE ACHIEVED</span>
                            <span class="badge-custom danger fs-6 mt-1">
                                <i class="bi bi-percent"></i> @Model.Score / 100
                            </span>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted d-block small">DATE RECORDED</span>
                            <span class="fw-bold text-secondary">@Model.Date.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                    </div>
                </div>

                <!-- Action Forms -->
                <div class="d-flex flex-column flex-sm-row justify-content-between gap-3 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn-custom btn-secondary-custom">
                        <i class="bi bi-arrow-left"></i> Cancel and Keep Record
                    </a>
                    
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn-custom btn-danger-custom shadow-sm w-100">
                            <i class="bi bi-trash3-fill"></i> Confirm Deletion
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
