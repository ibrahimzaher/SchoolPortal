@using SchoolPortal.GradesApp.ViewModles
@model GradeCreateViewModel

@{
    ViewData["Title"] = "Assign Grade";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Assign New Grade</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="StudentId" class="form-label fw-bold"></label>
                <select asp-for="StudentId" asp-items="Model.StudentsList" class="form-select">
                    <option value="">-- Select a Registered Student --</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CourseName" class="form-label fw-bold"></label>
                <input asp-for="CourseName" class="form-control" placeholder="e.g. Advanced Web Development" />
                <span asp-validation-for="CourseName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label fw-bold"></label>
                <input asp-for="Score" type="number" step="0.01" class="form-control" placeholder="0.00 - 100.00" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label fw-bold">Teacher Notes (Optional)</label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add feedback or remarks..."></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-success">Save Grade</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}