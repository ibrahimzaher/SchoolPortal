@using SchoolPortal.GradesApp.ViewModles
@model IEnumerable<GradeIndexViewModel>

@{
    ViewData["Title"] = "Grades Directory";
}

<div class="d-flex justify-content-between align-items-center mb-3 px-2 px-md-0">
    <h2 class="text-primary fs-3 fs-md-2">Academic Grades</h2>
    <a asp-action="Create" class="btn btn-success btn-sm btn-md-md">
        + Assign New Grade
    </a>
</div>

@if (Model.Any(m => m.StudentName.Contains("Unavailable")))
{
    <div class="alert alert-warning alert-dismissible fade show mx-2 mx-md-0" role="alert">
        <strong><i class="bi bi-exclamation-triangle-fill"></i> Connection Notice:</strong> Some student names could not be retrieved because the Students Service is currently offline. Temporary IDs are displayed.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mx-2 mx-md-0">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 responsive-table">
            <thead class="table-dark text-center">
                <tr>
                    <th>Student Name</th>
                    <th>Course Name</th>
                    <th>Score</th>
                    <th>Date Assigned</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No grades recorded yet. Click "Assign New Grade" to start.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="text-center align-middle">
                        <td class="fw-bold" data-label="Student Name">
                            @if (item.StudentName.Contains("Unavailable"))
                            {
                                <span class="text-danger"><i class="bi bi-wifi-off"></i> Student ID: @item.StudentId</span>
                            }
                            else
                            {
                                @item.StudentName
                            }
                        </td>
                        <td data-label="Course Name">@item.CourseName</td>
                        <td data-label="Score">
                            <span class="badge @(item.Score >= 50 ? "bg-success" : "bg-danger") fs-6">
                                @item.Score / 100
                            </span>
                        </td>
                        <td data-label="Date Assigned">@item.Date.ToString("yyyy-MM-dd HH:mm")</td>
                        <td data-label="Actions" class="mobile-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
