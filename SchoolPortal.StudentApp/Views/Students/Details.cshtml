@model Student

@{
    ViewData["Title"] = "Student Profile";

    // Dynamic Age Calculation
    var ageString = "N/A";
    if (Model.DateOfBirth.HasValue)
    {
        var dob = Model.DateOfBirth.Value;
        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - dob.Year;
        if (dob > today.AddYears(-age)) age--;
        ageString = $"{age} Years Old";
    }
}

<div class="row justify-content-center mx-2 mx-md-0">
    <div class="col-lg-8">
        <div class="card-custom">
            <!-- Profile header with large avatar fallback -->
            <div class="card-header-custom py-4 bg-white text-center d-flex flex-column align-items-center">
                <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 72px; height: 72px;">
                    <i class="bi bi-person-fill display-5"></i>
                </div>
                <h4 class="mb-1 text-main fw-bold text-gradient">@Model.FirstName @Model.LastName</h4>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-1.5 rounded-pill fw-bold small">
                    <i class="bi bi-shield-check"></i> Active Student
                </span>
            </div>

            <div class="card-body-custom p-4">
                <!-- Large Highlight Stats Bar -->
                <div class="bg-light rounded p-4 mb-4 border d-flex flex-column flex-md-row align-items-center justify-content-around gap-3">
                    <div class="text-center">
                        <span class="text-muted uppercase small fw-bold d-block mb-1">STUDENT ID</span>
                        <span class="fs-4 fw-bold text-main">#@Model.Id</span>
                    </div>
                    <div class="vr d-none d-md-block" style="height: 40px;"></div>
                    <hr class="d-md-none w-100 my-1">
                    <div class="text-center">
                        <span class="text-muted uppercase small fw-bold d-block mb-1">AGE</span>
                        <span class="fs-4 fw-bold text-main">@ageString</span>
                    </div>
                    <div class="vr d-none d-md-block" style="height: 40px;"></div>
                    <hr class="d-md-none w-100 my-1">
                    <div class="text-center">
                        <span class="text-muted uppercase small fw-bold d-block mb-1">ENROLLMENT STATUS</span>
                        <span class="badge-custom success py-1.5 px-3 fs-7">
                            <i class="bi bi-patch-check-fill"></i> Registered
                        </span>
                    </div>
                </div>

                <!-- Profile description list grid -->
                <dl class="dl-custom row mb-0 mt-4">
                    <div class="col-md-6 mb-3">
                        <dt><i class="bi bi-person-fill text-muted me-1"></i> First Name</dt>
                        <dd>@Model.FirstName</dd>
                    </div>
                    <div class="col-md-6 mb-3">
                        <dt><i class="bi bi-person-fill text-muted me-1"></i> Last Name</dt>
                        <dd>@Model.LastName</dd>
                    </div>
                    <div class="col-md-6 mb-3">
                        <dt><i class="bi bi-envelope-fill text-muted me-1"></i> Email Address</dt>
                        <dd class="text-primary">
                            <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                        </dd>
                    </div>
                    <div class="col-md-6 mb-3">
                        <dt><i class="bi bi-calendar-event-fill text-muted me-1"></i> Date of Birth</dt>
                        <dd>@(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "N/A")</dd>
                    </div>
                    <div class="col-12 mb-3">
                        <dt><i class="bi bi-calendar-check-fill text-muted me-1"></i> System Enrollment Date</dt>
                        <dd>@Model.EnrollmentDate.ToString("yyyy-MM-dd HH:mm")</dd>
                    </div>
                </dl>

                <!-- Footer Actions -->
                <div class="d-flex flex-column flex-sm-row justify-content-between gap-3 mt-5 pt-3 border-top">
                    <a asp-action="Index" class="btn-custom btn-secondary-custom">
                        <i class="bi bi-arrow-left"></i> Back to Directory
                    </a>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-custom btn-warning-custom text-white">
                            <i class="bi bi-pencil-fill"></i> Edit Profile
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-custom btn-danger-custom">
                            <i class="bi bi-trash3-fill"></i> Delete Student
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
