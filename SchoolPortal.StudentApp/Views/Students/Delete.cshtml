@model Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="card border-danger shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h4>
    </div>
    <div class="card-body text-center py-4">
        <h5 class="text-dark mb-3">Are you sure you want to permanently delete this student?</h5>
        <p class="fs-4 fw-bold text-danger mb-1">@Model.FirstName @Model.LastName</p>
        <p class="text-muted small">Email: @Model.Email</p>
    </div>
    <div class="card-footer bg-light d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
        </form>
    </div>
</div>
