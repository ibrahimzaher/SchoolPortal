@model IEnumerable<Student>
@{
    ViewData["Title"] = "Students List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-primary">Students Directory</h2>
    <a asp-action="Create" class="btn btn-success">
        + Add New Student
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr class="text-center">
                    <th>Full Name</th>
                    <th>Email Address</th>
                    <th>Enrollment Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No students found. Click "Add New Student" to start.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="text-center ">
                        <td>@item.FirstName @item.LastName</td>
                        <td>@item.Email</td>
                        <td>@item.EnrollmentDate.ToString("yyyy-MM-dd")</td>
        
                        <td class="d-flex flex-row gap-2 justify-content-between">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning w-100">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white w-100">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger w-100">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
