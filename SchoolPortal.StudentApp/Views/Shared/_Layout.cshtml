@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolPortal.Students</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolPortal.StudentApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light navbar-custom fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand navbar-brand-custom text-gradient" asp-area="" asp-controller="Students" asp-action="Index">
                    <i class="bi bi-mortarboard-fill text-primary"></i>
                    <span>SchoolPortal <span class="badge bg-primary-subtle text-primary border border-primary-subtle fs-7 ms-1">Students</span></span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" 
                        aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <ul class="navbar-nav ms-auto mb-2 mb-md-0 gap-1 mt-2 mt-md-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Students" ? "active" : "")" 
                               asp-area="" asp-controller="Students" asp-action="Index">
                                <i class="bi bi-people-fill"></i> Students Directory
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" href="@Configuration["ExternalServices:GradesPortalUrl"]/">
                                <i class="bi bi-journal-bookmark-fill"></i> Grades Portal <i class="bi bi-box-arrow-up-right small text-muted"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")" 
                               asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock-fill"></i> Privacy
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container" style="margin-top: 100px; margin-bottom: 40px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container text-center">
            <span class="fw-semibold">&copy; 2026 - SchoolPortal Student Administration</span>
            <span class="mx-2 text-muted">|</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-primary fw-semibold">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
